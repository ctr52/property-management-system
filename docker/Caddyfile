# Фронт стенда: отдаёт SPA и проксирует API на бэкенд.
#
# Адрес сайта берётся из переменной SITE_ADDRESS (её задаёт compose из .env):
#   - не задана           → ":80"  → просто HTTP на IP машины;
#   - домен (pms.site.ru) → Caddy САМ берёт сертификат Let's Encrypt и поднимает
#                            HTTPS на :443 с авто-продлением (нужен A-record на IP
#                            и открытый порт 443 в security group).
# Ничего кроме этой переменной для HTTPS менять не нужно — ни certbot, ни cron.

{$SITE_ADDRESS::80} {
	encode gzip

	# API и все вебхуки — на бэкенд. Префикс /api сохраняем (API смонтирован под /api).
	handle /api/* {
		reverse_proxy api:3000
	}

	# Остальное — статика SPA. Фолбэк на index.html для client-side роутинга.
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
