# ─────────────────────────────────────────────────────────────────────
#  Шаблон для GitHub Secret  PROD_ENV
#  Скопируй, заполни значения и вставь ВСЁ содержимое в секрет PROD_ENV.
#  На каждом деплое workflow запишет это в ~/pms/.env на ВМ.
#
#  Топологию стенда (адреса эмуляторов, PORT, PG_DATA) сюда НЕ добавляй —
#  она уже проставлена в docker-compose.prod.yml и переопределит .env.
# ─────────────────────────────────────────────────────────────────────

# Домен для авто-HTTPS (Let's Encrypt через Caddy). Нужен A-record домена на IP ВМ
# и открытый порт 443. Оставь ПУСТЫМ/закомментированным — будет работать по HTTP на :80.
# SITE_ADDRESS=pms.твой-домен.ру

# Публичный адрес стенда — куда провайдеры возвращают браузер (/guest, /payment/return).
# Без домена: http://<IP_машины>. С доменом (SITE_ADDRESS задан): https://<домен>.
WEB_BASE_URL=http://CHANGE_ME
PUBLIC_BASE_URL=http://CHANGE_ME

# Avito: номер аккаунта в путях API (в эмуляторе — любой).
AVITO_USER_ID=1

# Cian: период опроса статуса публикации, сек (боевой дефолт 1800).
CIAN_FEEDBACK_POLL_SEC=1800

# YooKassa — SaaS-биллинг подписки (эмулятора НЕТ; для теста возьми тестовый
# магазин из кабинета yookassa.ru → Интеграция). Без ключей биллинг подписки не поедет.
YOOKASSA_API_BASE=https://api.yookassa.ru/v3
YOOKASSA_PLATFORM_SHOP_ID=
YOOKASSA_PLATFORM_SECRET_KEY=

# Тариф/триал (см. модуль subscriptions). Значения — на твой вкус.
DEFAULT_PLAN_ID=
DEFAULT_PLAN_PRICE_MINOR=
TRIAL_DAYS=14

# Необязательное — раскомментируй при необходимости:
# CARD_HOLD_AMOUNT_MINOR=1000
# TENTATIVE_TTL_MS=
# TRIAL_EXPIRY_POLL_SEC=
