# Скопируй в `.env` и при необходимости поправь. Подхватывается `pnpm dev:mock`.

# --- Песочница (apps/sandbox): каждый эмулятор на своём порту ---
# Хаб со ссылками: http://localhost:4000
# Базы API площадок → эмуляторы
AVITO_API_BASE=http://localhost:4001
CIAN_API_BASE=http://localhost:4002

# Частый опрос статуса публикации Cian (get-order); прод-дефолт 1800
CIAN_FEEDBACK_POLL_SEC=15

# Avito: номер аккаунта в путях API (в моке любой)
AVITO_USER_ID=1

# --- Платёжные эмуляторы (Robokassa/Точка) ---
ROBOKASSA_API_BASE=http://localhost:4010
TOCHKA_API_BASE=http://localhost:4011

# База web-SPA — куда провайдер возвращает браузер после оплаты (/guest, /payment/return).
WEB_BASE_URL=http://localhost:5173

# --- YooKassa: SaaS-биллинг тенанта (org платит НАМ за PMS) ---
# Это платёжный шлюз ПОДПИСКИ (привязка карты auth-hold'ом + рекуррент), НЕ приём оплат броней.
# Кабинет: https://yookassa.ru/my → «Интеграция» → shopId и секретный ключ.
YOOKASSA_PLATFORM_SHOP_ID=
YOOKASSA_PLATFORM_SECRET_KEY=
# База API. Боевой дефолт уже стоит в коде; для песочницы укажите тестовый shopId/ключ из кабинета.
YOOKASSA_API_BASE=https://api.yookassa.ru/v3
# Куда YooKassa вернёт браузер после привязки карты — страница подписки нашей SPA.
# returnUrl формирует фронт как `${origin}/billing`; отдельной переменной не требуется.
# В кабинете YooKassa пропишите URL уведомлений (webhook) на наш бэкенд:
#   https://<ваш-домен>/api/billing-webhooks/yookassa
